// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}


model User {
  UserID    String    @id @default(uuid()) 
  FName String 
  LName String
  Email String @unique
  College String?
  xp Int @default(0)
  Level Int @default(0)
  record Record?
}

model Record {
  RecID String @id @default(uuid())
  DailyQuestCompleted Int @default(0)
  DailyQuestAssign Int @default(0)
  QuestsCompleted Int @default(0)
  BossQuestCompleted Int @default(0)
  user User @relation(fields: [UserRec], references: [UserID])
  UserRec String @unique
}


